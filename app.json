{
  "expo": {
    "name": "EvolutFit",
    "slug": "evolufit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/evolutFitLogo.png",
    "scheme": "evolufitmobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/evolutFitLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deibygs.evolufit"
    },
    "android": {
      "package": "com.deibygs.evolufit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/evolutFitLogo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/evolutFitLogo.png"
    },
    "plugins": ["expo-router", "@react-native-community/datetimepicker"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
